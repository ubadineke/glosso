{
  "name": "glosso",
  "version": "0.1.1",
  "description": "Agentic wallet infrastructure for Solana — SDK + CLI in one install",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "glosso": "./bin/glosso.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@glosso/sdk": "^0.1.1",
    "@glosso/cli": "^0.1.1"
  },
  "keywords": ["solana", "wallet", "agent", "ai", "defi", "glosso"],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
