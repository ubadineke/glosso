# ============================================
# GLOSSO WALLET CONFIGURATION
# ============================================

# Wallet mode: sovereign | privy | turnkey
GLOSSO_MODE=sovereign

# Network: devnet | mainnet-beta
GLOSSO_NETWORK=devnet

# --- Sovereign Mode ---
GLOSSO_MASTER_SEED_ENCRYPTED=
GLOSSO_ENCRYPTION_PASSPHRASE=

# --- Privy Mode ---
# GLOSSO_PRIVY_APP_ID=
# GLOSSO_PRIVY_APP_SECRET=
# GLOSSO_PRIVY_WALLET_ID=

# --- Turnkey Mode ---
# GLOSSO_TURNKEY_API_PUBLIC_KEY=
# GLOSSO_TURNKEY_API_PRIVATE_KEY=
# GLOSSO_TURNKEY_ORGANIZATION_ID=
# GLOSSO_TURNKEY_WALLET_ID=
