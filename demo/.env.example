# ── Grok / xAI ────────────────────────────────────────────
# Get your key at: https://console.x.ai → API Keys
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override model (default: grok-3-mini-fast)
# GROK_MODEL=grok-4-fast

# ── Glosso Wallet ──────────────────────────────────────────
# Run provisioning to generate these:
#   npx tsx packages/cli/src/index.ts provision --dir . --mode sovereign
GLOSSO_MODE=sovereign
GLOSSO_NETWORK=devnet
GLOSSO_PRIMARY_ADDRESS=
GLOSSO_MASTER_SEED_ENCRYPTED=
GLOSSO_ENCRYPTION_PASSPHRASE=
