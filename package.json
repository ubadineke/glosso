{
  "name": "glosso",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic Wallet Infrastructure for Solana",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rm -rf dist",
    "test:connection": "pnpm --filter @glosso/core test:connection",
    "test:derive": "pnpm --filter @glosso/core test:derive",
    "test:sovereign": "pnpm --filter @glosso/core test:sovereign",
    "test:adapters": "tsx packages/core/src/test-adapters.ts",
    "test:cli": "tsx packages/cli/src/test-cli.ts",
    "test:sdk": "tsx packages/sdk/src/test-sdk.ts",
    "test:skills": "tsx packages/skills/test-skills.ts",
    "glosso": "tsx packages/cli/src/index.ts"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
